<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE-edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="../main.css" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
    />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

    <title>Portfolio</title>
  </head>
  <body>
    <div class="frame">
      <div class="main_frame">
        <div class="left_frame">
          <div class="profile">
            <div class="profile_pic">
              <img
                src="images/profile.png"
                width="156px"
                height="142px"
                alt=""
              />
            </div>
            <div class="profile_name"><%=user.name%></div>
            <div class="profile_proff"><%=user.profession%></div>
            <div class="profile_icon">
              <a class="link_href" href="">
                <div class="icon">
                  <img src="icon/facebook.svg" class="icon-1" alt="" />
                </div>
              </a>

              <a class="link_href" href="">
                <div class="icon">
                  <img src="icon/instagram.svg" class="icon-1" alt="" />
                </div>
              </a>
              <a class="link_href" href="">
                <div class="icon">
                  <img src="icon/twitter.svg" class="icon-1" alt="" />
                </div>
              </a>
              <a class="link_href" href="">
                <div class="icon">
                  <img src="icon/linkedin.svg" class="icon-1" alt="" />
                </div>
              </a>
              <a class="link_href" href="">
                <div class="icon">
                  <img src="icon/youtube.svg" class="icon-1" alt="" />
                </div>
              </a>
              <a class="link_href" href="">
                <div class="icon">
                  <img src="icon/dribbble.svg" class="icon-1" alt="" />
                </div>
              </a>
            </div>
          </div>
          <div class="marginer"></div>
          <div class="about">
            <div class="age">
              <p>Age:</p>
              <%=user.age%>
            </div>
            <div class="residence">
              <p>Residence:</p>
              <%=user.residence%>
            </div>

            <div class="adress">
              <p>Adress:</p>
              <%=user.adress%>
            </div>
          </div>
          <div class="marginer"></div>
          <div class="languages"></div>
          <div class="marginer"></div>
          <div class="skills"></div>
          <div class="marginer"></div>
          <div class="extra_skills"></div>
          <div class="marginer"></div>
        </div>
        <div class="midd_frame"></div>
        <div class="right_frame"></div>
      </div>
    </div>
  </body>
</html>
